# docker/Dockerfile.reports
FROM python:3.11-slim

WORKDIR /app

# Install curl for healthcheck
RUN apt-get update && apt-get install -y curl && rm -rf /var/lib/apt/lists/*

# Copy and install dependencies from requirements.reports.txt file
COPY requirements.reports.txt .
RUN pip install --no-cache-dir -r requirements.reports.txt

# Copy the reports source code
COPY src/reports/ .

EXPOSE 8000

CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]